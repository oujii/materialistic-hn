---
import StoryRow from '../../components/StoryRow.astro';
import { getStories, type Section } from '../../lib/hn-read';

const VALID = ['top', 'new', 'best', 'ask', 'show', 'jobs'] as const;
const section = (Astro.url.searchParams.get('section') ?? 'top') as Section;
if (!VALID.includes(section as typeof VALID[number])) return Astro.redirect('/top');

const page = Math.max(2, parseInt(Astro.url.searchParams.get('page') ?? '2'));

let stories: Awaited<ReturnType<typeof getStories>> = [];
try {
  stories = await getStories(section, page, 30);
} catch {
  // return empty on error
}

const startRank = (page - 1) * 30 + 1;
const hasMore = stories.length === 30;

Astro.response.headers.set('X-Has-More', hasMore ? 'true' : 'false');
Astro.response.headers.set('Cache-Control', 'private, no-store');
---
{stories.map((story, i) => (
  <StoryRow story={story} rank={startRank + i} saved={false} />
))}
