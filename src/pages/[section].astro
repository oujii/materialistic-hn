---
import Base from '../layouts/Base.astro';
import DrawerMenu from '../components/DrawerMenu.astro';
import StoryRow from '../components/StoryRow.astro';
import { getStories, type Section } from '../lib/hn-read';
import { getSession } from '../lib/session';

const VALID_SECTIONS = ['top', 'new', 'best', 'ask', 'show', 'jobs'] as const;
const { section } = Astro.params;

if (!VALID_SECTIONS.includes(section as Section)) {
  return Astro.redirect('/top');
}

const session = await getSession(Astro.request);

const sectionLabel: Record<string, string> = {
  top: 'Top Stories',
  new: 'New Stories',
  best: 'Best',
  ask: 'Ask HN',
  show: 'Show HN',
  jobs: 'Jobs',
};

let stories = [];
let error = '';
try {
  stories = await getStories(section as Section, 1, 30);
} catch (e) {
  error = 'Failed to load stories. Please try again.';
}
// Saved indicator is filled in client-side from /api/favorites (sessionStorage cache)
const savedIds = new Set<number>();

// Never let CDN cache listing pages — they contain per-user bookmark state
Astro.response.headers.set('Cache-Control', 'private, no-store');

const label = sectionLabel[section] ?? 'Top Stories';
---

<Base title={`${label} — Materialistic`}>
  <DrawerMenu username={session?.username} currentSection={section} />

  <!-- Top bar -->
  <header class="sticky top-0 z-30 bg-hn-amber shadow-sm">
    <div class="flex items-center h-16 px-4 gap-4">
      <button onclick="openDrawer()" class="p-1 -ml-1 text-gray-900" aria-label="Menu">
        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
          <path d="M3 18v-2h18v2zm0-5v-2h18v2zm0-5V6h18v2z"/>
        </svg>
      </button>
      <div class="flex-1 ml-2">
        <h1 class="text-gray-900 font-medium text-xl leading-tight">{label}</h1>
        <p class="text-gray-900/70 text-base mt-0.5" id="last-updated">Last updated 0 min ago</p>
      </div>
      <a href={`/search`} class="p-1 text-gray-900" aria-label="Search">
        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
          <path d="m19.6 21l-6.3-6.3q-.75.6-1.725.95T9.5 16q-2.725 0-4.612-1.888T3 9.5t1.888-4.612T9.5 3t4.613 1.888T16 9.5q0 1.1-.35 2.075T14.7 13.3l6.3 6.3zM9.5 14q1.875 0 3.188-1.312T14 9.5t-1.312-3.187T9.5 5T6.313 6.313T5 9.5t1.313 3.188T9.5 14"/>
        </svg>
      </a>
      <button class="p-1 text-gray-900" aria-label="More">
        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 20q-.825 0-1.412-.587T10 18t.588-1.412T12 16t1.413.588T14 18t-.587 1.413T12 20m0-6q-.825 0-1.412-.587T10 12t.588-1.412T12 10t1.413.588T14 12t-.587 1.413T12 14m0-6q-.825 0-1.412-.587T10 6t.588-1.412T12 4t1.413.588T14 6t-.587 1.413T12 8"/>
        </svg>
      </button>
    </div>
  </header>

  <!-- Single shared overflow menu — opened by tap on any story's "..." button.
       instant-nav.js fills in the targets from the story's data-story attribute. -->
  <div id="story-menu" class="hidden fixed inset-0 z-30">
    <div class="absolute right-4 bg-white rounded-lg shadow-xl border border-gray-200 overflow-hidden" style="top: 60px; min-width: 180px">
      <a id="story-menu-article" target="_blank" rel="noopener" class="block px-4 py-3 text-sm text-gray-700 hover:bg-gray-50">Open Article</a>
      <a id="story-menu-hn" target="_blank" rel="noopener" class="block px-4 py-3 text-sm text-gray-700 hover:bg-gray-50">Open on HN</a>
      <button id="story-menu-save" class="block w-full text-left px-4 py-3 text-sm text-gray-700 hover:bg-gray-50">Save Story</button>
      <button id="story-menu-share" class="block w-full text-left px-4 py-3 text-sm text-gray-700 hover:bg-gray-50">Share</button>
    </div>
  </div>

  <!-- Pull-to-refresh indicator -->
  <div id="ptr-indicator" class="fixed top-16 left-0 right-0 z-20 flex justify-center pointer-events-none transition-transform duration-200" style="transform: translateY(-60px)">
    <div class="bg-white rounded-full shadow-lg w-10 h-10 flex items-center justify-center">
      <svg id="ptr-arrow" class="w-5 h-5 text-hn-orange transition-transform duration-200" fill="currentColor" viewBox="0 0 24 24">
        <path d="M12 4v12m0 0l-5-5m5 5l5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
      </svg>
    </div>
  </div>

  <!-- Story list -->
  <main>
    {error ? (
      <div class="p-8 text-center text-gray-500">{error}</div>
    ) : (
      <div>
        <div id="story-list">
          {stories.map((story, i) => (
            <StoryRow story={story} rank={i + 1} saved={savedIds.has(story.id)} />
          ))}
        </div>

        <!-- Infinite scroll sentinel -->
        <div id="load-sentinel" class="flex items-center justify-center py-6">
          <div id="load-spinner" class="flex items-center gap-2 text-gray-400 text-sm">
            <svg class="w-5 h-5 animate-spin" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/>
            </svg>
            Loading more…
          </div>
          <div id="load-done" class="hidden text-gray-300 text-sm">All stories loaded</div>
        </div>
      </div>
    )}
  </main>
</Base>

<script is:inline>
function initSectionPage() {
  // Clean up listeners from a previous client-side navigation to this page
  if (window._sectionCleanup) { window._sectionCleanup(); }
  const ctrl = new AbortController();
  const sig = ctrl.signal;
  window._sectionCleanup = function() { ctrl.abort(); };
  // Fire cleanup before ViewTransitions swaps the page
  document.addEventListener('astro:before-swap', window._sectionCleanup, { once: true });

  const section = window.location.pathname.slice(1).split('?')[0] || 'top';
  // Restore scroll position if we just came back from an article
  var backKey = 'hn-back-' + section;
  var savedScroll = sessionStorage.getItem(backKey);
  if (savedScroll) {
    try {
      var pos = JSON.parse(savedScroll);
      if (typeof pos.y === 'number') {
        setTimeout(function() { window.scrollTo(0, pos.y); }, 0);
      }
    } catch (_) {}
    sessionStorage.removeItem(backKey);
  }
  let page = 1;
  let loading = false;
  let hasMore = true;
  const loadedAt = Date.now();

  // Last-updated counter
  function updateLastUpdated() {
    const elapsed = Math.floor((Date.now() - loadedAt) / 60000);
    const text = elapsed === 0 ? 'Last updated 0 min ago'
      : elapsed === 1 ? 'Last updated 1 min ago'
      : 'Last updated ' + elapsed + ' min ago';
    const el = document.getElementById('last-updated');
    if (el) el.textContent = text;
  }
  updateLastUpdated();
  const timer = setInterval(updateLastUpdated, 30000);
  sig.addEventListener('abort', function() { clearInterval(timer); });

  // BFCACHE: reload if restored from back-forward cache after >3 min of being away
  window.addEventListener('pageshow', function(e) {
    if (e.persisted && Date.now() - loadedAt > 3 * 60 * 1000) {
      window.location.reload();
    }
  }, { signal: sig });

  // Infinite scroll
  const sentinel = document.getElementById('load-sentinel');
  const storyList = document.getElementById('story-list');
  if (sentinel && storyList) {
    const observer = new IntersectionObserver(function(entries) {
      if (!entries[0].isIntersecting || loading || !hasMore) return;
      loadMore();
    }, { rootMargin: '300px' });
    observer.observe(sentinel);
    sig.addEventListener('abort', function() { observer.disconnect(); });
  }

  async function loadMore() {
    if (loading || !hasMore) return;
    loading = true;
    page++;
    const spinner = document.getElementById('load-spinner');
    if (spinner) spinner.classList.remove('hidden');
    try {
      const res = await fetch('/partial/stories?section=' + section + '&page=' + page);
      const nextHasMore = res.headers.get('X-Has-More') === 'true';
      const html = await res.text();
      const doc = new DOMParser().parseFromString(html, 'text/html');
      const list = document.getElementById('story-list');
      if (list) {
        Array.from(doc.body.childNodes).forEach(function(node) {
          if (node.nodeType === 1 && (node.nodeName === 'SCRIPT' || node.nodeName === 'STYLE')) return;
          list.appendChild(document.importNode(node, true));
        });
      }
      hasMore = nextHasMore;
      if (!hasMore) {
        if (spinner) spinner.classList.add('hidden');
        const done = document.getElementById('load-done');
        if (done) done.classList.remove('hidden');
      }
    } catch {
      page--; // allow retry on next scroll
    } finally {
      loading = false;
      const spinner2 = document.getElementById('load-spinner');
      if (hasMore && spinner2) spinner2.classList.add('hidden');
    }
  }

  // Pull-to-refresh
  const ptr = document.getElementById('ptr-indicator');
  const ptrArrow = document.getElementById('ptr-arrow');
  const PTR_THRESHOLD = 80;
  let startY = 0;
  let pulling = false;
  let pullDist = 0;

  document.addEventListener('touchstart', function(e) {
    if (window.scrollY <= 0) { startY = e.touches[0].clientY; pulling = true; }
  }, { passive: true, signal: sig });

  document.addEventListener('touchmove', function(e) {
    if (!pulling) return;
    pullDist = e.touches[0].clientY - startY;
    if (pullDist > 0) {
      var offset = Math.min(pullDist * 0.5, 100);
      if (ptr) ptr.style.transform = 'translateY(' + (offset - 60) + 'px)';
      if (ptrArrow) ptrArrow.style.transform = pullDist > PTR_THRESHOLD ? 'rotate(180deg)' : 'rotate(0deg)';
    }
  }, { passive: true, signal: sig });

  document.addEventListener('touchend', function() {
    if (!pulling) return;
    pulling = false;
    if (pullDist > PTR_THRESHOLD) {
      if (ptr) ptr.style.transform = 'translateY(20px)';
      if (ptrArrow) ptrArrow.classList.add('animate-spin');
      window.location.reload();
    } else {
      if (ptr) ptr.style.transform = 'translateY(-60px)';
    }
    pullDist = 0;
  }, { signal: sig });
}
// astro:page-load fires once on the initial load AND after every
// ViewTransitions swap — unlike a plain top-level call, this re-attaches the
// scroll listener / observer / scroll-restore on every visit to this page,
// not just the very first time the script tag is parsed.
document.addEventListener('astro:page-load', initSectionPage);
</script>
