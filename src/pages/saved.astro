---
import Base from '../layouts/Base.astro';
import DrawerMenu from '../components/DrawerMenu.astro';
import { getSession } from '../lib/session';
import { fetchFavorites } from '../lib/hn-scrape';
import { getDomain, timeAgo } from '../lib/hn-read';

const session = await getSession(Astro.request);
if (!session) return Astro.redirect('/login');

let stories = [];
let error = '';
try {
  stories = await fetchFavorites(session.username, session.cookie);
} catch (e) {
  error = 'Could not load saved stories.';
}
---

<Base title="Saved Stories — Materialistic">
  <DrawerMenu username={session.username} currentSection="saved" />

  <header class="sticky top-0 z-30 bg-hn-amber shadow-sm">
    <div class="flex items-center h-16 px-4 gap-4">
      <button onclick="openDrawer()" class="p-1 -ml-1 text-gray-900">
        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
          <path d="M3 18v-2h18v2zm0-5v-2h18v2zm0-5V6h18v2z"/>
        </svg>
      </button>
      <h1 class="text-gray-900 font-bold text-lg ml-2">Saved Stories</h1>
    </div>
  </header>

  <main>
    {error ? (
      <div class="p-8 text-center text-gray-500">{error}</div>
    ) : stories.length === 0 ? (
      <div class="p-8 text-center text-gray-400">
        <svg class="w-12 h-12 mx-auto mb-3 opacity-30" fill="currentColor" viewBox="0 0 24 24">
          <path d="M17 3H7c-1.1 0-1.99.9-1.99 2L5 21l7-3 7 3V5c0-1.1-.9-2-2-2z"/>
        </svg>
        <p class="text-sm">No saved stories yet.</p>
        <p class="text-xs mt-1">Tap ⋮ on any story to save it.</p>
      </div>
    ) : (
      <div>
        {stories.map((story, i) => (
          <a href={`/item/${story.id}`} class="story-row relative flex items-stretch border-b border-gray-200 bg-white visited:bg-gray-100 hover:bg-gray-50 transition-colors active:bg-gray-100">
            <div class="relative w-16 flex-shrink-0 flex flex-col items-center justify-center gap-1 bg-[#FFE0B2]">
              <svg class="absolute top-0 left-1 w-5 h-5 text-hn-orange" fill="currentColor" viewBox="0 0 24 24">
                <path d="M5 21V5q0-.825.588-1.412T7 3h10q.825 0 1.413.588T19 5v16l-7-3z"/>
              </svg>
              <span class="text-lg font-medium text-gray-800 leading-none">{i + 1}</span>
              {story.score && <span class="text-sm text-gray-600 leading-none">{story.score}p</span>}
            </div>
            <div class="flex-1 py-4 px-3 min-w-0">
              <p class="text-[18px] text-hn-text-primary leading-snug line-clamp-3">{story.title}</p>
              <p class="text-[14px] text-gray-400 italic mt-0 leading-tight truncate">{story.domain}</p>
              {story.by && <p class="text-[14px] text-gray-400 mt-0 leading-tight truncate">{story.by}</p>}
            </div>
            <div class="flex-shrink-0 flex items-center gap-2 pr-3 py-4">
              <span class="flex items-center gap-1">
                <svg class="w-5 h-5 text-hn-comment" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M21.99,4c0,-1.1 -0.89,-2 -1.99,-2L4,2c-1.1,0 -2,0.9 -2,2v12c0,1.1 0.9,2 2,2h14l4,4 -0.01,-18zM18,14L6,14v-2h12v2zM18,11L6,11L6,9h12v2zM18,8L6,8L6,6h12v2z"/>
                </svg>
                <span class="text-sm font-semibold text-hn-comment">{story.comments ?? 0}</span>
              </span>
            </div>
          </a>
        ))}
      </div>
    )}
  </main>
</Base>
