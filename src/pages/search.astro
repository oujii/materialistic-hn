---
import Base from '../layouts/Base.astro';
import DrawerMenu from '../components/DrawerMenu.astro';
import { getSession } from '../lib/session';

const session = await getSession(Astro.request);
const initialQuery = Astro.url.searchParams.get('q') ?? '';
Astro.response.headers.set('Cache-Control', 'private, no-store');
---

<Base title={initialQuery ? `${initialQuery} — Search` : 'Search — Materialistic'}>
  <DrawerMenu username={session?.username} currentSection="search" />

  <!-- Top bar with search input -->
  <header class="sticky top-0 z-30 bg-hn-amber shadow-sm">
    <div class="flex items-center h-16 px-2 gap-1">
      <a href="/top" class="p-2 -ml-1 text-gray-900" aria-label="Back">
        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
          <path d="m7.825 13l5.6 5.6L12 20l-8-8l8-8l1.425 1.4l-5.6 5.6H20v2z"/>
        </svg>
      </a>
      <input
        id="search-input"
        type="search"
        autocomplete="off"
        autocapitalize="none"
        autocorrect="off"
        spellcheck="false"
        placeholder="Search Hacker News…"
        value={initialQuery}
        class="flex-1 bg-transparent border-0 outline-none text-gray-900 placeholder-gray-700/60 text-lg px-2 py-2 focus:ring-0"
      />
      <button id="search-clear" class="p-2 text-gray-900 hidden" aria-label="Clear">
        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 13.4l-4.9 4.9q-.275.275-.7.275t-.7-.275t-.275-.7t.275-.7l4.9-4.9l-4.9-4.9q-.275-.275-.275-.7t.275-.7t.7-.275t.7.275l4.9 4.9l4.9-4.9q.275-.275.7-.275t.7.275t.275.7t-.275.7L13.4 12l4.9 4.9q.275.275.275.7t-.275.7t-.7.275t-.7-.275z"/>
        </svg>
      </button>
    </div>
    <!-- Sort tabs -->
    <div class="flex">
      <button data-sort="popularity" class="flex-1 text-center py-2 text-xs font-bold tracking-wide border-b-2 text-gray-900 border-red-500">
        RELEVANCE
      </button>
      <button data-sort="date" class="flex-1 text-center py-2 text-xs font-bold tracking-wide border-b-2 text-gray-700/60 border-transparent">
        NEWEST
      </button>
    </div>
  </header>

  <main>
    <div id="search-status" class="p-6 text-center text-gray-400 text-sm">
      Type to search Hacker News
    </div>
    <div id="search-results" class="hidden"></div>
    <p class="text-center text-xs text-gray-300 py-4">
      Powered by <a href="https://hn.algolia.com" target="_blank" rel="noopener" class="underline">HN Search by Algolia</a>
    </p>
  </main>
</Base>

<script is:inline data-astro-rerun define:vars={{ initialQuery }}>
  (function () {
    var ALGOLIA = 'https://hn.algolia.com/api/v1/';
    var input = document.getElementById('search-input');
    var clearBtn = document.getElementById('search-clear');
    var status = document.getElementById('search-status');
    var results = document.getElementById('search-results');
    var sortBtns = document.querySelectorAll('button[data-sort]');
    if (!input || !results || !status) return;

    var currentSort = 'popularity'; // or 'date'
    var debounceTimer = null;
    var abortCtrl = null;

    function timeAgo(unix) {
      var d = Math.floor(Date.now() / 1000) - unix;
      if (d < 60) return d + 's';
      if (d < 3600) return Math.floor(d / 60) + 'm';
      if (d < 86400) return Math.floor(d / 3600) + 'h';
      if (d < 604800) return Math.floor(d / 86400) + 'd';
      return Math.floor(d / 604800) + 'w';
    }
    function getDomain(url) {
      if (!url) return 'news.ycombinator.com';
      try { return new URL(url).hostname.replace(/^www\./, ''); } catch (e) { return ''; }
    }
    function escAttr(s) {
      return String(s == null ? '' : s)
        .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;').replace(/'/g, '&#39;');
    }
    function escText(s) {
      return String(s == null ? '' : s)
        .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
    }

    function renderRow(hit, rank) {
      var id = hit.objectID;
      var title = hit.title || hit.story_title || '(no title)';
      var url = hit.url || hit.story_url || ('https://news.ycombinator.com/item?id=' + id);
      var author = hit.author || '';
      var score = hit.points != null ? hit.points : 0;
      var descendants = hit.num_comments != null ? hit.num_comments : 0;
      var time = hit.created_at_i || Math.floor(Date.now() / 1000);
      var domain = getDomain(hit.url);
      var ago = timeAgo(time);
      var isHot = score >= 200;

      var story = {
        id: parseInt(id, 10),
        title: title,
        by: author,
        time: time,
        score: score,
        descendants: descendants,
        kids: [],
        url: hit.url,
        text: null,
      };
      var storyAttr = escAttr(JSON.stringify(story));

      var commentIcon = isHot
        ? '<svg class="w-5 h-5 text-hn-fire flex-shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M4 14q0-2.625 1.25-4.675T8 5.875t2.75-2.138L12 3v3.3q0 .925.625 1.462t1.4.538q.425 0 .813-.175t.712-.575L16 7q1.8 1.05 2.9 2.912T20 14q0 2.2-1.075 4.013T16.1 20.874q.425-.6.663-1.312T17 18.05q0-1-.375-1.888t-1.075-1.587L12 11.1l-3.525 3.475q-.725.725-1.1 1.6T7 18.05q0 .8.238 1.513t.662 1.312q-1.75-1.05-2.825-2.863T4 14m8-.1l2.125 2.075q.425.425.65.95T15 18.05q0 1.225-.875 2.088T12 21t-2.125-.862T9 18.05q0-.575.225-1.112t.65-.963z"/></svg>'
        : '<svg class="w-5 h-5 text-hn-comment flex-shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M21.99,4c0,-1.1 -0.89,-2 -1.99,-2L4,2c-1.1,0 -2,0.9 -2,2v12c0,1.1 0.9,2 2,2h14l4,4 -0.01,-18zM18,14L6,14v-2h12v2zM18,11L6,11L6,9h12v2zM18,8L6,8L6,6h12v2z"/></svg>';
      var commentColor = isHot ? 'text-hn-fire' : 'text-hn-comment';

      return ''
        + '<a href="/item/' + id + '" data-story="' + storyAttr + '" data-saved="false" '
        + 'class="story-row relative flex items-stretch border-b border-gray-200 bg-white active:bg-gray-100">'
        +   '<div class="relative w-16 flex-shrink-0 flex flex-col items-center justify-center gap-1 bg-[#FFE0B2]">'
        +     '<span class="text-lg font-medium text-gray-800 leading-none">' + rank + '</span>'
        +     '<span class="text-sm leading-none ' + (isHot ? 'text-hn-fire font-semibold' : 'text-gray-600') + '">' + score + 'p</span>'
        +   '</div>'
        +   '<div class="flex-1 py-1.5 px-2 min-w-0">'
        +     '<p class="story-title text-[18px] text-hn-text-primary leading-tight">' + escText(title) + '</p>'
        +     '<p class="text-[14px] text-gray-400 italic mt-0 leading-tight">' + escText(domain) + '</p>'
        +     '<div class="flex items-start justify-between gap-2">'
        +       '<p class="text-[14px] text-gray-400 leading-tight flex-1 min-w-0 pt-0">' + escText(ago) + (author ? ' - ' + escText(author) : '') + '</p>'
        +       '<div class="flex items-center gap-1 flex-shrink-0 -mt-1">'
        +         (descendants > 0
          ? '<span class="flex items-center gap-1">' + commentIcon + '<span class="text-sm font-semibold ' + commentColor + ' min-w-[3ch] tabular-nums text-left">' + descendants + '</span></span>'
          : '')
        +       '</div>'
        +     '</div>'
        +   '</div>'
        + '</a>';
    }

    function setStatus(text, isError) {
      status.textContent = text;
      status.className = 'p-6 text-center text-sm ' + (isError ? 'text-red-400' : 'text-gray-400');
      status.classList.remove('hidden');
      results.classList.add('hidden');
    }

    function showResults(html) {
      results.innerHTML = html;
      results.classList.remove('hidden');
      status.classList.add('hidden');
    }

    async function search(q) {
      if (!q || q.length < 2) {
        setStatus(q.length === 0 ? 'Type to search Hacker News' : 'Type at least 2 characters');
        return;
      }
      if (abortCtrl) abortCtrl.abort();
      abortCtrl = new AbortController();
      setStatus('Searching…');
      var endpoint = currentSort === 'date' ? 'search_by_date' : 'search';
      var url = ALGOLIA + endpoint + '?query=' + encodeURIComponent(q) + '&tags=story&hitsPerPage=30';
      try {
        var res = await fetch(url, { signal: abortCtrl.signal });
        if (!res.ok) { setStatus('Search failed (' + res.status + ')', true); return; }
        var data = await res.json();
        var hits = data.hits || [];
        if (!hits.length) {
          setStatus('No results for “' + q + '”');
          return;
        }
        var html = '';
        for (var i = 0; i < hits.length; i++) html += renderRow(hits[i], i + 1);
        showResults(html);
        // Update URL without reloading
        if (location.search.indexOf(encodeURIComponent(q)) === -1) {
          history.replaceState(null, '', '/search?q=' + encodeURIComponent(q));
        }
      } catch (e) {
        if (e.name === 'AbortError') return;
        setStatus('Network error — check your connection', true);
      }
    }

    function onInput() {
      var q = input.value.trim();
      clearBtn.classList.toggle('hidden', !q);
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(function () { search(q); }, 220);
    }

    input.addEventListener('input', onInput);
    input.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') { input.value = ''; onInput(); input.blur(); }
    });
    clearBtn.addEventListener('click', function () {
      input.value = '';
      input.focus();
      onInput();
    });
    sortBtns.forEach(function (b) {
      b.addEventListener('click', function () {
        currentSort = b.getAttribute('data-sort');
        sortBtns.forEach(function (x) {
          var active = x === b;
          x.className = 'flex-1 text-center py-2 text-xs font-bold tracking-wide border-b-2 ' + (active ? 'text-gray-900 border-red-500' : 'text-gray-700/60 border-transparent');
        });
        search(input.value.trim());
      });
    });

    // Initial query from URL
    if (initialQuery) {
      clearBtn.classList.remove('hidden');
      search(initialQuery);
    } else {
      // Autofocus on empty search (no scroll for keyboard popup feel)
      setTimeout(function () { input.focus({ preventScroll: true }); }, 100);
    }
  })();
</script>
