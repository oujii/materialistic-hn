---
interface Props {
  title?: string;
}
const { title = 'Materialistic' } = Astro.props;
---
<!DOCTYPE html>
<html lang="en" class="h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#FFB74D" />
    <meta name="color-scheme" content="light only" />
    <title>{title}</title>
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="apple-touch-icon" href="/icons/icon-192.png" />
    <link rel="icon" href="/icons/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Roboto:ital,wght@0,400;0,500;0,700;1,400&display=swap" />
  </head>
  <body class="h-full bg-white text-gray-900 font-sans">
    <slot />

    <!-- PWA install banner: Chrome uses beforeinstallprompt; Firefox/others get manual instructions -->
    <div id="install-banner" class="hidden fixed bottom-4 left-4 right-4 z-50">
      <div class="bg-white rounded-xl shadow-2xl border border-amber-200 p-4 flex items-center gap-3">
        <img src="/icons/icon-192.png" class="w-10 h-10 rounded-xl flex-shrink-0" alt="Materialistic" />
        <div class="flex-1 min-w-0">
          <p class="text-sm font-semibold text-gray-900">Install Materialistic</p>
          <p id="install-hint" class="text-xs text-gray-500">Add to your home screen</p>
        </div>
        <button id="install-action" class="bg-hn-orange text-white text-sm font-semibold px-3 py-1.5 rounded-lg hover:bg-orange-600 transition-colors">
          Install
        </button>
        <button onclick="document.getElementById('install-banner').classList.add('hidden'); localStorage.setItem('install-dismissed', '1')" class="text-gray-300 hover:text-gray-500 p-1">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Firefox install instructions modal -->
    <div id="ff-instructions" class="hidden fixed inset-0 bg-black/40 z-50 flex items-center justify-center p-4" onclick="document.getElementById('ff-instructions').classList.add('hidden')">
      <div class="bg-white rounded-xl max-w-sm p-6" onclick="event.stopPropagation()">
        <h2 class="text-lg font-bold mb-3">Install on Firefox</h2>
        <ol class="text-sm text-gray-700 space-y-2 list-decimal pl-5">
          <li>Tap the menu (⋮) in Firefox's address bar</li>
          <li>Tap <strong>"Install"</strong> or <strong>"Add to Home Screen"</strong></li>
          <li>Confirm to add Materialistic to your launcher</li>
        </ol>
        <button onclick="document.getElementById('ff-instructions').classList.add('hidden')" class="mt-4 bg-hn-orange text-white text-sm font-semibold px-4 py-2 rounded-lg w-full">Got it</button>
      </div>
    </div>

    <!-- Toast notification -->
    <div id="toast" style="display:none; position:fixed; bottom:24px; left:50%; transform:translateX(-50%); z-index:9999; background:#111827; color:white; font-size:14px; padding:10px 16px; border-radius:8px; box-shadow:0 10px 25px rgba(0,0,0,0.3); max-width:90%; text-align:center;"></div>

    <script is:inline>
      window.showToast = function(message, duration) {
        var t = document.getElementById('toast');
        if (!t) { alert(message); return; }
        t.textContent = message;
        t.style.display = 'block';
        t.style.opacity = '1';
        clearTimeout(window.__toastTimer);
        window.__toastTimer = setTimeout(function() {
          t.style.opacity = '0';
          setTimeout(function() { t.style.display = 'none'; }, 200);
        }, duration || 2500);
      };
    </script>

    <script src="/sw-register.js" defer></script>
    <script>
      const dismissed = localStorage.getItem('install-dismissed');
      const isStandalone = window.matchMedia('(display-mode: standalone)').matches || window.navigator.standalone;
      const ua = navigator.userAgent.toLowerCase();
      const isFirefox = ua.includes('firefox');
      const isIOSSafari = /iphone|ipad/.test(ua) && /safari/.test(ua) && !/crios|fxios/.test(ua);

      if (!dismissed && !isStandalone) {
        let deferredPrompt;

        // Chrome / Edge / Samsung Internet — use the standard prompt
        window.addEventListener('beforeinstallprompt', (e) => {
          e.preventDefault();
          deferredPrompt = e;
          document.getElementById('install-banner').classList.remove('hidden');
          const btn = document.getElementById('install-action');
          btn.onclick = () => deferredPrompt?.prompt();
        });

        // Firefox / iOS Safari — show banner with manual instructions
        if (isFirefox || isIOSSafari) {
          setTimeout(() => {
            document.getElementById('install-banner').classList.remove('hidden');
            const hint = document.getElementById('install-hint');
            const btn = document.getElementById('install-action');
            if (isFirefox) {
              hint.textContent = 'Open Firefox menu → Install';
              btn.textContent = 'How?';
              btn.onclick = () => document.getElementById('ff-instructions').classList.remove('hidden');
            } else if (isIOSSafari) {
              hint.textContent = 'Share → Add to Home Screen';
              btn.textContent = 'OK';
              btn.onclick = () => {
                document.getElementById('install-banner').classList.add('hidden');
                localStorage.setItem('install-dismissed', '1');
              };
            }
          }, 2000);
        }
      }
    </script>
  </body>
</html>
