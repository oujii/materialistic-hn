---
import type { HNItem } from '../lib/hn-read';
import { timeAgo, getDomain, isHot } from '../lib/hn-read';

interface Props {
  story: HNItem;
  rank: number;
  saved?: boolean;
}
const { story, rank, saved = false } = Astro.props;
const hot = isHot(story.score);
const domain = getDomain(story.url);
const ago = timeAgo(story.time);
---

<a href={`/item/${story.id}`} class="story-row relative flex items-stretch border-b border-gray-200 bg-white hover:bg-gray-50 transition-colors active:bg-gray-100">
  <!-- Rank + score column (orange, vertically centered) -->
  <div class="relative w-16 flex-shrink-0 flex flex-col items-center justify-center gap-1 bg-[#FFE0B2]">
    {saved && (
      <svg class="absolute top-0 left-1 w-5 h-5 text-hn-orange" fill="currentColor" viewBox="0 0 24 24">
        <path d="M5 21V5q0-.825.588-1.412T7 3h10q.825 0 1.413.588T19 5v16l-7-3z"/>
      </svg>
    )}
    <span class="text-lg font-medium text-gray-800 leading-none">{rank}</span>
    <span class={`text-sm leading-none ${hot ? 'text-hn-fire font-semibold' : 'text-gray-600'}`}>
      {story.score}p
    </span>
    {hot && (
      <svg class="w-5 h-5 text-hn-fire" fill="currentColor" viewBox="0 0 24 24">
        <path d="M4 14q0-2.625 1.25-4.675T8 5.875t2.75-2.138L12 3v3.3q0 .925.625 1.462t1.4.538q.425 0 .813-.175t.712-.575L16 7q1.8 1.05 2.9 2.912T20 14q0 2.2-1.075 4.013T16.1 20.874q.425-.6.663-1.312T17 18.05q0-1-.375-1.888t-1.075-1.587L12 11.1l-3.525 3.475q-.725.725-1.1 1.6T7 18.05q0 .8.238 1.513t.662 1.312q-1.75-1.05-2.825-2.863T4 14m8-.1l2.125 2.075q.425.425.65.95T15 18.05q0 1.225-.875 2.088T12 21t-2.125-.862T9 18.05q0-.575.225-1.112t.65-.963z"/>
      </svg>
    )}
  </div>

  <!-- Title + meta + actions, stacked. Title is full-width, actions sit on right below it. -->
  <div class="flex-1 py-2 px-2 min-w-0">
    <p class="story-title text-[18px] text-hn-text-primary leading-snug">
      {story.title}
    </p>
    <p class="text-[14px] text-gray-400 italic mt-0 leading-tight">{domain}</p>
    <!-- Bottom row: meta on left, comment + dots on right -->
    <div class="flex items-end justify-between gap-2 mt-0 pb-1">
      <p class="text-[14px] text-gray-400 leading-tight flex-1 min-w-0">
        {ago}{story.by ? ` - ${story.by}` : ''}
      </p>
      <div class="flex items-center gap-1 flex-shrink-0">
        {(story.descendants ?? 0) > 0 && (
          <span class="flex items-center gap-1">
            {hot ? (
              <>
                <svg class="w-5 h-5 text-hn-fire flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M4 14q0-2.625 1.25-4.675T8 5.875t2.75-2.138L12 3v3.3q0 .925.625 1.462t1.4.538q.425 0 .813-.175t.712-.575L16 7q1.8 1.05 2.9 2.912T20 14q0 2.2-1.075 4.013T16.1 20.874q.425-.6.663-1.312T17 18.05q0-1-.375-1.888t-1.075-1.587L12 11.1l-3.525 3.475q-.725.725-1.1 1.6T7 18.05q0 .8.238 1.513t.662 1.312q-1.75-1.05-2.825-2.863T4 14m8-.1l2.125 2.075q.425.425.65.95T15 18.05q0 1.225-.875 2.088T12 21t-2.125-.862T9 18.05q0-.575.225-1.112t.65-.963z"/>
                </svg>
                <span class="text-sm font-semibold text-hn-fire min-w-[3ch] tabular-nums text-left">{story.descendants}</span>
              </>
            ) : (
              <>
                <svg class="w-5 h-5 text-hn-comment flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M21.99,4c0,-1.1 -0.89,-2 -1.99,-2L4,2c-1.1,0 -2,0.9 -2,2v12c0,1.1 0.9,2 2,2h14l4,4 -0.01,-18zM18,14L6,14v-2h12v2zM18,11L6,11L6,9h12v2zM18,8L6,8L6,6h12v2z"/>
                </svg>
                <span class="text-sm font-semibold text-hn-comment min-w-[3ch] tabular-nums text-left">{story.descendants}</span>
              </>
            )}
          </span>
        )}
        <button
          onclick={`event.preventDefault(); event.stopPropagation(); toggleMenu(${story.id})`}
          class="p-1 -mr-1 text-gray-500 hover:text-gray-700 rounded"
          aria-label="More options"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 20q-.825 0-1.412-.587T10 18t.588-1.412T12 16t1.413.588T14 18t-.587 1.413T12 20m0-6q-.825 0-1.412-.587T10 12t.588-1.412T12 10t1.413.588T14 12t-.587 1.413T12 14m0-6q-.825 0-1.412-.587T10 6t.588-1.412T12 4t1.413.588T14 6t-.587 1.413T12 8"/>
          </svg>
        </button>
      </div>
    </div>
  </div>
</a>

<!-- Overflow menu (hidden) -->
<div id={`menu-${story.id}`} class="hidden fixed inset-0 z-30" onclick={`hideMenu(${story.id})`}>
  <div class="absolute right-4 bg-white rounded-lg shadow-xl border border-gray-200 overflow-hidden" style="top: 60px; min-width: 180px">
    <a href={story.url ?? `https://news.ycombinator.com/item?id=${story.id}`} target="_blank" rel="noopener" class="block px-4 py-3 text-sm text-gray-700 hover:bg-gray-50" onclick={`hideMenu(${story.id})`}>
      Open Article
    </a>
    <a href={`https://news.ycombinator.com/item?id=${story.id}`} target="_blank" rel="noopener" class="block px-4 py-3 text-sm text-gray-700 hover:bg-gray-50" onclick={`hideMenu(${story.id})`}>
      Open on HN
    </a>
    <button
      class="block w-full text-left px-4 py-3 text-sm text-gray-700 hover:bg-gray-50"
      onclick={`saveStory(${story.id}); hideMenu(${story.id})`}
    >
      {saved ? 'Unsave' : 'Save Story'}
    </button>
    <button
      class="block w-full text-left px-4 py-3 text-sm text-gray-700 hover:bg-gray-50"
      onclick={`shareStory('${story.title?.replace(/'/g, "\\'")}', '${story.url ?? ''}'); hideMenu(${story.id})`}
    >
      Share
    </button>
  </div>
</div>

<script>
  function toggleMenu(id: number) {
    const el = document.getElementById(`menu-${id}`);
    el?.classList.toggle('hidden');
  }
  function hideMenu(id: number) {
    document.getElementById(`menu-${id}`)?.classList.add('hidden');
  }
  async function saveStory(id: number) {
    try {
      const res = await fetch('/api/save', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id }),
      });
      if (res.status === 401) {
        window.location.href = '/login';
      }
    } catch {
      // silent
    }
  }
  function shareStory(title: string, url: string) {
    if (navigator.share) {
      navigator.share({ title, url });
    } else {
      navigator.clipboard.writeText(url);
    }
  }
  (window as any).toggleMenu = toggleMenu;
  (window as any).hideMenu = hideMenu;
  (window as any).saveStory = saveStory;
  (window as any).shareStory = shareStory;
</script>

<style>
  .story-row:visited .story-title {
    color: #9ca3af; /* gray-400, matches the original "read" indicator */
  }
</style>
